```mermaid
classDiagram
    %% ===== MODELOS =====
    class Libro {
        -String isbn
        -String titulo
        -String autor
        -String categoria
        -int cantidadTotal
        -int cantidadDisponible
        +estaDisponible() boolean
        +reducirDisponibilidad() void
        +aumentarDisponibilidad() void
    }

    class Socio {
        -String id
        -String nombre
        -String documento
        -String telefono
        -String email
        -double multaAcumulada
        +tieneMultasPendientes() boolean
        +acumularMulta(monto) void
        +pagarMulta(monto) void
    }

    class Prestamo {
        -String id
        -Libro libro
        -Socio socio
        -Date fechaPrestamo
        -Date fechaVencimiento
        -Date fechaDevolucion
        -double multaGenerada
        -boolean devuelto
        +estaVencido() boolean
        +calcularMulta() double
        +registrarDevolucion() void
    }

    %% ===== REPOSITORIOS =====
    class Repository~T~ {
        <<interface>>
        +agregar(item) void
        +buscarPorId(id) T
        +listar() T[]
        +eliminar(id) void
    }

    class LibroRepository {
        -Libro[] libros
        +buscarPorCriterio(criterio) Libro[]
    }

    class SocioRepository {
        -Socio[] socios
    }

    class PrestamoRepository {
        -Prestamo[] prestamos
        +listarActivos() Prestamo[]
        +listarPorSocio(socioId) Prestamo[]
    }

    %% ===== SERVICIOS =====
    class CatalogoService {
        -LibroRepository libroRepository
        +agregarLibro(libro) void
        +eliminarLibro(isbn) void
        +buscarLibro(criterio) Libro[]
    }

    class SocioService {
        -SocioRepository socioRepository
        +registrarSocio(socio) void
        +editarSocio(id, datos) void
        +eliminarSocio(id) void
        +tieneMultasPendientes(id) boolean
    }

    class PrestamoService {
        -LibroRepository libroRepository
        -SocioRepository socioRepository
        -PrestamoRepository prestamoRepository
        -PoliticaMulta politicaMulta
        +realizarPrestamo(socio, libro) Prestamo
        +registrarDevolucion(idPrestamo) void
        +listarPrestamosActivos() Prestamo[]
        +generarReporteMasPrestados() Libro[]
    }

    class PoliticaMulta {
        <<interface>>
        +calcular(diasAtraso) double
    }

    class PoliticaMultaFija {
        -double montoPorDia
        +calcular(diasAtraso) double
    }

    %% ===== UI =====
    class MenuCommand {
        <<interface>>
        +descripcion String
        +ejecutar() void
    }

    class RegistrarLibroCommand {
        -CatalogoService catalogoService
        -Prompts prompts
        +ejecutar() void
    }

    class RealizarPrestamoCommand {
        -PrestamoService prestamoService
        -SocioRepository socioRepository
        -LibroRepository libroRepository
        -Prompts prompts
        +ejecutar() void
    }

    class Menu {
        -MenuCommand[] comandos
        -Prompts prompts
        +mostrar() void
        +ejecutarOpcion(indice) void
        +iniciar() void
    }

    class Prompts {
        +preguntar(texto) String
        +cerrar() void
    }

    %% ===== RELACIONES =====
    LibroRepository ..|> Repository
    SocioRepository ..|> Repository
    PrestamoRepository ..|> Repository

    LibroRepository "1" o-- "*" Libro
    SocioRepository "1" o-- "*" Socio
    PrestamoRepository "1" o-- "*" Prestamo
    Prestamo "*" --> "1" Libro
    Prestamo "*" --> "1" Socio

    CatalogoService --> LibroRepository
    SocioService --> SocioRepository
    PrestamoService --> LibroRepository
    PrestamoService --> SocioRepository
    PrestamoService --> PrestamoRepository
    PrestamoService --> PoliticaMulta

    PoliticaMultaFija ..|> PoliticaMulta

    RegistrarLibroCommand ..|> MenuCommand
    RealizarPrestamoCommand ..|> MenuCommand
    RegistrarLibroCommand --> CatalogoService
    RealizarPrestamoCommand --> PrestamoService

    Menu "1" o-- "*" MenuCommand
    Menu --> Prompts
